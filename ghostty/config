# Ghostty configuration
#
# Symlinked to ~/.config/ghostty/config by ghostty/install.sh.
# Reference: https://ghostty.org/docs/config/reference

# Font (Pro profile used Fira Code Bold @ 18; installed via Brewfile's font-fira-code)
font-family = "Fira Code"
font-style = Bold
font-size = 18

# Window transparency (your bg alpha was ~0.81)
background-opacity = 0.81

# Core colors (converted from Display P3 -> sRGB)
background = #3c3a47
foreground = #f1f1f1
bold-color = #ffffff
selection-background = #6e3a1f
selection-foreground = #ffffff

# Cursor — bright and saturated so it pops against the transparent bg
cursor-color = #ffcc00
cursor-text = #1a1a1a
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor